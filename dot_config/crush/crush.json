{
  "$schema": "https://charm.land/crush.json",
  "mcp": {
    "context7": {
      "type": "http",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "$CONTEXT7_API_KEY"
      }
    },
    "serena": {
      "type": "stdio",
      "command": "serena",
      "args": [
        "start-mcp-server",
        "--context=ide",
        "--enable-web-dashboard=false"
      ]
    }
  },
  "lsp": {
    "nix": {
      "command": "nil"
    },
    "typescript": {
      "command": "typescript-language-server",
      "args": [
        "--stdio"
      ],
      "root_markers": [
        "tsconfig.json",
        "package.json"
      ]
    },
    "python": {
      "command": "pyright-langserver",
      "args": [
        "--stdio"
      ]
    },
    "rust": {
      "command": "rust-analyzer"
    },
    "go": {
      "command": "gopls"
    },
    "ruby": {
      "command": "ruby-lsp"
    }
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "^bash$",
        "command": "hooks/rtk-rewrite.sh"
      }
    ]
  },
  "options": {
    "skills_paths": [
      "~/.claude/skills"
    ],
    "auto_lsp": true,
    "debug": false,
    "tui": {
      "diff_mode": "unified"
    },
    "attribution": {
      "trailer_style": "assisted-by",
      "generated_with": true
    }
  },
  "permissions": {
    "allowed_tools": [
      "view",
      "ls",
      "glob",
      "grep",
      "lsp_diagnostics",
      "lsp_references",
      "fetch",
      "agent"
    ]
  }
}
