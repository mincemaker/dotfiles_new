{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "external_directory": {
      "{env:WIKI_PATH}/**": "allow"
    },
    "read": {
      "{env:WIKI_PATH}/**": "allow"
    },
    "edit": {
      "{env:WIKI_PATH}/wiki/**": "allow"
    },
    "bash": {
      "rtk ls *": "allow",
      "rtk read *": "allow",
      "rtk grep *": "allow",
      "plocate --version": "allow",
      "locate --version": "allow",
      "plocate -S": "allow",
      "locate -S": "allow",
      "plocate -e /": "allow",
      "updatedb --help": "allow",
      "findmnt *": "allow",
      "find {env:WIKI_PATH}*": "allow",
      "ls {env:WIKI_PATH}*": "allow"
    }
  },
  "plugin": [
    "./plugins/guard.ts",
    "./plugins/rtk.ts",
    "./plugins/plan-mo.ts"
  ],
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
      "headers": {
        "CONTEXT7_API_KEY": "${CONTEXT7_API_KEY}"
      }
    },
    "serena": {
      "type": "local",
      "command": [
        "uvx",
        "-p",
        "3.13",
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server"
      ],
      "enabled": true
    }
  }
}
